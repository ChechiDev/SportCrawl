  # Database
  DB__HOST=localhost
  DB__PORT=5432
  DB__NAME=sportcrawl
  DB__USER=sportcrawl
  DB__PASSWORD=sportcrawl
  DB__POOL_SIZE=5
  DB__MAX_OVERFLOW=10
  DB__POOL_TIMEOUT=30
  DB__POOL_RECYCLE=1800
  DB__SSL_MODE=disable

  # Scraping
  SCRAPING__CDP_WS_URL=ws://localhost:9222
  SCRAPING__WORK_SERVER_URL=http://localhost:9731
  SCRAPING__WORK_SERVER_TOKEN=dev-token-ci
  SCRAPING__MAX_RETRIES=3
  SCRAPING__BASE_DELAY=1.0
  SCRAPING__MAX_DELAY=60.0
  SCRAPING__REQUEST_TIMEOUT=30
  SCRAPING__ALLOWED_HOSTS=["fbref.com"]
  SCRAPING__MAX_CONCURRENT_REQUESTS=3
  SCRAPING__REQUEST_DELAY_MIN=3.0
  SCRAPING__REQUEST_DELAY_MAX=10.0
  SCRAPING__MAX_QUEUE_RETRIES=5

  # App
  ENV=dev
  LOG_LEVEL=INFO
