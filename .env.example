# Environment template for sportcrawl.
# Copy this file to .env and fill in real values.
# DO NOT commit .env or any file containing real credentials.
#
# GitHub CI secret required: DB_PASSWORD (set in repo Settings > Secrets)

# Application settings
ENV=dev
LOG_LEVEL=INFO

# Database connection (DB__* prefix)
DB__HOST=localhost
DB__PORT=5432
DB__NAME=sportcrawl
DB__USER=sportcrawl
DB__PASSWORD=change-me-before-use
DB__POOL_SIZE=5
DB__MAX_OVERFLOW=10
DB__POOL_TIMEOUT=30

# SSL mode: required in prod, can be disable in dev
# Accepted values: require | disable
DB__SSL_MODE=disable

# Scraping settings (SCRAPING__* prefix)
SCRAPING__MAX_RETRIES=3
SCRAPING__BASE_DELAY=1.0
SCRAPING__MAX_DELAY=60.0
SCRAPING__REQUEST_TIMEOUT=30
SCRAPING__WORK_SERVER_URL=http://localhost:9731
SCRAPING__WORK_SERVER_TOKEN=change-me-before-use
